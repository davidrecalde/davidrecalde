---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Work — David Recalde"
  description="Institutions and organizations I've worked with across design, communication and digital strategy between Spain, Japan and Europe."
>
  <Nav currentPage="work" />
  <main id="main-content" class="flex-1">

    <!-- Page header -->
    <section class="hero-enter mx-auto max-w-[960px] w-full px-[clamp(20px,5vw,40px)] pt-[clamp(48px,8vw,96px)] pb-[clamp(36px,5vw,56px)]">
      <p class="mb-4 font-sans text-xs font-medium uppercase tracking-[0.16em] text-muted">(03) Work</p>
      <h1 class="m-0 font-display font-medium text-[clamp(44px,7vw,72px)] leading-none tracking-[-0.02em] text-ink">Work</h1>
      <p class="mt-7 max-w-[52ch] font-sans text-[17px] leading-[1.7] text-muted">
        Institutions and organizations I&rsquo;ve worked with or collaborated on, across design, communication and digital strategy.
      </p>
    </section>

    <!-- Work table -->
    <section class="mx-auto max-w-[960px] w-full px-[clamp(20px,5vw,40px)] pb-[clamp(56px,8vw,96px)]">
      <table class="work-table">
        <thead>
          <tr>
            <th>Institution</th>
            <th>Sector</th>
            <th>Collaboration</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="work-name">Instituto Cervantes Tokyo</td>
            <td class="work-sector">Cultural Institution</td>
            <td class="work-role">Communication Advisor</td>
          </tr>
          <tr>
            <td class="work-name">Embassy of Spain in Japan</td>
            <td class="work-sector">Government</td>
            <td class="work-role">Digital Content</td>
          </tr>
          <tr>
            <td class="work-name">JICA</td>
            <td class="work-sector">Government Agency</td>
            <td class="work-role">Language Instructor</td>
          </tr>
          <tr>
            <td class="work-name">ICEX</td>
            <td class="work-sector">Trade &amp; Investment</td>
            <td class="work-role">Collaboration</td>
          </tr>
          <tr>
            <td class="work-name">University of Tokyo</td>
            <td class="work-sector">Academic</td>
            <td class="work-role">Graphic Design</td>
          </tr>
          <tr>
            <td class="work-name">NODA.Tokyo</td>
            <td class="work-sector">Studio</td>
            <td class="work-role">Studio Lead</td>
          </tr>
          <tr>
            <td class="work-name">supein.club</td>
            <td class="work-sector">Own Platform</td>
            <td class="work-role">Founder</td>
          </tr>
        </tbody>
      </table>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script>
  import { initWorkTableAnimation, initHoverPolish } from '../scripts/scroll-animations';
  initWorkTableAnimation();
  initHoverPolish();
</script>
