---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    num: '01',
    title: 'Digital Communication',
    desc: 'Strategy, content and platform development for cultural and institutional organizations working between Spain and Japan.',
  },
  {
    num: '02',
    title: 'Design & Branding',
    desc: 'Visual identity, editorial and digital design. From concept to execution — for clients that need both strategic thinking and craft.',
  },
  {
    num: '03',
    title: 'SEO & Content Strategy',
    desc: 'Multilingual SEO architecture and content strategy for digital platforms targeting Japanese and Spanish-speaking audiences.',
  },
];
---
<BaseLayout
  title="Services — David Recalde"
  description="Digital communication, design & branding, and SEO & content strategy. Consulting services for organizations working between Spain, Japan and Europe."
>
  <Nav currentPage="services" />
  <main id="main-content" class="flex-1">

    <!-- Page header -->
    <section class="hero-enter mx-auto max-w-[960px] w-full px-[clamp(20px,5vw,40px)] pt-[clamp(48px,8vw,96px)] pb-[clamp(32px,5vw,48px)]">
      <p class="mb-4 font-sans text-xs font-medium uppercase tracking-[0.16em] text-muted">What I offer</p>
      <h1 class="m-0 font-display font-medium text-[clamp(44px,7vw,72px)] leading-none tracking-[-0.02em] text-ink">Services</h1>
      <p class="mt-7 max-w-[52ch] font-sans text-[17px] leading-[1.7] text-muted">
        I work with organizations and brands that need a bridge between design, digital communication and the Spain&ndash;Japan space. Here&rsquo;s where I can help.
      </p>
    </section>

    <!-- Service rows -->
    <section data-reveal class="mx-auto max-w-[960px] w-full px-[clamp(20px,5vw,40px)] py-[clamp(28px,4vw,48px)]">
      {services.map((s, i) => (
        <div class:list={[
          'flex flex-wrap items-baseline gap-[clamp(24px,4vw,56px)] border-t border-border py-8',
          i === services.length - 1 && 'border-b',
        ]}>
          <div class="min-w-[240px] flex-[1_1_300px]">
            <span class="font-sans text-xs font-medium tracking-[0.14em] text-muted">{s.num}</span>
            <h2 class="mt-2.5 font-display font-medium text-[clamp(30px,4vw,40px)] leading-[1.1] tracking-[-0.01em] text-ink">{s.title}</h2>
          </div>
          <p class="m-0 min-w-[260px] flex-[1_1_340px] font-sans text-base leading-[1.7] text-muted">{s.desc}</p>
        </div>
      ))}
    </section>

    <!-- CTA -->
    <section data-reveal class="mx-auto max-w-[960px] w-full px-[clamp(20px,5vw,40px)] py-[clamp(48px,7vw,88px)] text-center">
      <h2 class="m-0 font-display font-medium text-[clamp(36px,6vw,52px)] leading-[1.05] tracking-[-0.02em] text-ink">Let&rsquo;s work together.</h2>
      <p class="mx-auto mt-5 max-w-[44ch] font-sans text-base leading-[1.7] text-muted">
        Tell me about your project and I&rsquo;ll get back to you.
      </p>
      <a
        href="/contact/"
        class="mt-8 inline-flex items-center gap-2 rounded-[5px] bg-accent px-[26px] py-3.5 font-sans text-[15px] font-medium text-white no-underline hover:bg-accent-dark active:scale-[0.98] transition-all duration-200"
      >Get in touch&nbsp;&rarr;</a>
    </section>

  </main>
  <Footer />
</BaseLayout>
