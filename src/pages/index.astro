---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import GridSystem from '../components/GridSystem.astro';
---
<BaseLayout
  title="David Recalde — Brand & Communication Strategist, Tokyo"
  description="Brand and communication strategist based in Tokyo. Founder of NODA.Tokyo and supein.club. Spain–Japan digital communication, branding and SEO."
>
  <Nav currentPage="home" />
  <main id="main-content" class="flex-1">

    <!-- Hero -->
    <section class="hero-fullscreen">
      <div class="hero-grid-bg" aria-hidden="true">
        <GridSystem columns={8} rows={5} />
      </div>
      <div class="hero-content">
        <h1 class="hero-tagline-xl">Design, Build, Grow.</h1>
        <p class="hero-name-sub">David Recalde</p>
        <p class="hero-role-sub">Brand &amp; Communication Strategist &mdash; Tokyo</p>
        <a
          href="/contact/"
          class="btn-primary hero-cta"
        >Get in touch&nbsp;&rarr;</a>
      </div>
      <div class="hero-scroll-hint" aria-hidden="true">
        <span></span>
      </div>
    </section>

    <!-- What I do -->
    <section class="mx-auto max-w-[960px] w-full border-t border-border px-[clamp(20px,5vw,40px)] py-[clamp(40px,6vw,72px)]">
      <p class="mb-8 font-sans text-xs font-medium uppercase tracking-[0.16em] text-muted">
        What I do
      </p>
      <div class="services-grid grid grid-cols-[repeat(auto-fit,minmax(250px,1fr))] gap-[clamp(28px,4vw,44px)]">
        <div class="service-card border-t border-ink pt-[20px]">
          <span class="font-sans text-xs font-medium tracking-[0.14em] text-muted">01</span>
          <h3 class="mx-0 mt-3 mb-2.5 font-display font-medium text-[25px] leading-[1.15] tracking-[-0.01em] text-ink">Digital Communication</h3>
          <p class="m-0 font-sans text-[15px] leading-[1.65] text-muted">Strategy, content and platform development for cultural and institutional organizations working between Spain and Japan.</p>
        </div>
        <div class="service-card border-t border-ink pt-[20px]">
          <span class="font-sans text-xs font-medium tracking-[0.14em] text-muted">02</span>
          <h3 class="mx-0 mt-3 mb-2.5 font-display font-medium text-[25px] leading-[1.15] tracking-[-0.01em] text-ink">Design &amp; Branding</h3>
          <p class="m-0 font-sans text-[15px] leading-[1.65] text-muted">Visual identity, editorial and digital design. From concept to execution — for clients that need both strategic thinking and craft.</p>
        </div>
        <div class="service-card border-t border-ink pt-[20px]">
          <span class="font-sans text-xs font-medium tracking-[0.14em] text-muted">03</span>
          <h3 class="mx-0 mt-3 mb-2.5 font-display font-medium text-[25px] leading-[1.15] tracking-[-0.01em] text-ink">SEO &amp; Content Strategy</h3>
          <p class="m-0 font-sans text-[15px] leading-[1.65] text-muted">Multilingual SEO architecture and content strategy for digital platforms targeting Japanese and Spanish-speaking audiences.</p>
        </div>
      </div>
    </section>

    <!-- Client logos -->
    <section class="mx-auto max-w-[960px] w-full border-t border-border px-[clamp(20px,5vw,40px)] pt-[clamp(32px,5vw,52px)] pb-[clamp(40px,6vw,64px)]">
      <p class="mb-6 font-sans text-xs font-medium uppercase tracking-[0.16em] text-muted">
        Selected clients &amp; institutions
      </p>
      <div class="logo-row">
        <img src="/images/logos/instituto-cervantes.svg" alt="Instituto Cervantes Tokyo" loading="lazy" />
        <img src="/images/logos/embassy-spain.svg" alt="Embassy of Spain in Japan" loading="lazy" />
        <img src="/images/logos/jica.svg" alt="JICA — Japan International Cooperation Agency" loading="lazy" />
        <img src="/images/logos/icex.svg" alt="ICEX — Spain Trade and Investment" loading="lazy" />
        <img src="/images/logos/utokyo.svg" alt="University of Tokyo" loading="lazy" />
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script>
  import { initScrollAnimations, initHoverPolish } from '../scripts/scroll-animations';
  initScrollAnimations();
  initHoverPolish();
</script>
