---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="David Recalde — Designer & Communication Consultant, Tokyo"
  description="Designer and communication consultant based in Tokyo. Founder of NODA.Tokyo and supein.club. Spain–Japan digital communication, branding and SEO."
>
  <Nav currentPage="home" />
  <main class="flex-1">
    <div class="animate-fade-up">

      <!-- Hero -->
      <section class="mx-auto max-w-[960px] w-full px-[clamp(20px,5vw,40px)] py-[clamp(44px,8vw,104px)] pb-[clamp(44px,7vw,80px)]">
        <div class="flex flex-wrap items-center gap-[clamp(32px,6vw,72px)]">
          <div class="min-w-[280px] flex-[1_1_380px]">
            <h1 class="m-0 font-display font-medium text-[clamp(52px,9vw,92px)] leading-none tracking-[-0.015em] text-ink">
              David Recalde<span class="text-accent">·</span>
            </h1>
            <p class="mt-[26px] max-w-[30ch] font-sans text-[clamp(18px,2.2vw,21px)] leading-[1.45] text-ink">
              Designer &amp; Communication Consultant based in Tokyo.
            </p>
            <p class="mt-5 max-w-[42ch] font-sans text-base leading-[1.7] text-muted">
              I help brands and institutions build their digital presence at the intersection of Spain, Japan and Europe.
            </p>
            <a
              href="/contact/"
              class="mt-[34px] inline-flex items-center gap-2 rounded bg-accent px-[26px] py-3.5 font-sans text-[15px] font-medium tracking-[0.01em] text-white no-underline hover:bg-accent-dark transition-colors duration-200"
            >Get in touch&nbsp;&rarr;</a>
          </div>
          <div class="min-w-[240px] max-w-[380px] w-full flex-[0_1_340px]">
            <div class="relative aspect-square w-full overflow-hidden rounded-sm border border-border bg-[#F6F6F4]">
              <img
                src="/images/david-recalde.jpg"
                alt="David Recalde — Designer and Communication Consultant based in Tokyo"
                class="absolute inset-0 h-full w-full object-cover"
                loading="eager"
              />
            </div>
          </div>
        </div>
      </section>

      <!-- Short intro -->
      <section class="mx-auto max-w-[960px] w-full border-t border-border px-[clamp(20px,5vw,40px)] py-[clamp(40px,6vw,72px)]">
        <p class="m-0 max-w-[48ch] font-sans text-[clamp(18px,2.3vw,22px)] leading-[1.6] text-ink">
          With a background in product design and over a decade working in Tokyo, I focus on digital communication, branding and SEO for organizations that operate between Spain, Japan and Europe.
        </p>
        <p class="mt-7 font-sans text-[13px] font-medium tracking-[0.04em] text-muted">
          Studio Lead at NODA.Tokyo&nbsp;&middot;&nbsp;Founder of supein.club
        </p>
      </section>

      <!-- Client logos -->
      <section class="mx-auto max-w-[960px] w-full border-t border-border px-[clamp(20px,5vw,40px)] pt-[clamp(36px,5vw,56px)] pb-[clamp(40px,6vw,64px)]">
        <p class="mb-7 font-sans text-xs font-medium uppercase tracking-[0.16em] text-muted">
          Selected clients &amp; institutions
        </p>
        <div class="flex flex-wrap items-center gap-x-10 gap-y-[18px]">
          {['Instituto Cervantes', 'Embassy of Spain', 'JICA', 'ICEX', 'University of Tokyo'].map(name => (
            <span class="font-sans text-[13px] font-semibold uppercase tracking-[0.1em] text-muted">{name}</span>
          ))}
        </div>
      </section>

      <!-- 3 Services -->
      <section class="mx-auto max-w-[960px] w-full border-t border-border px-[clamp(20px,5vw,40px)] py-[clamp(40px,6vw,72px)]">
        <p class="mb-10 font-sans text-xs font-medium uppercase tracking-[0.16em] text-muted">
          What I do
        </p>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(250px,1fr))] gap-[clamp(32px,4vw,48px)]">
          <div class="border-t border-ink pt-[22px]">
            <span class="font-sans text-xs font-medium tracking-[0.14em] text-muted">01</span>
            <h3 class="mx-0 mt-3.5 mb-3 font-display font-medium text-[27px] leading-[1.15] text-ink">Digital Communication</h3>
            <p class="m-0 font-sans text-[15px] leading-[1.65] text-muted">Strategy, content and platform development for cultural and institutional organizations working between Spain and Japan.</p>
          </div>
          <div class="border-t border-ink pt-[22px]">
            <span class="font-sans text-xs font-medium tracking-[0.14em] text-muted">02</span>
            <h3 class="mx-0 mt-3.5 mb-3 font-display font-medium text-[27px] leading-[1.15] text-ink">Design &amp; Branding</h3>
            <p class="m-0 font-sans text-[15px] leading-[1.65] text-muted">Visual identity, editorial and digital design. From concept to execution — for clients that need both strategic thinking and craft.</p>
          </div>
          <div class="border-t border-ink pt-[22px]">
            <span class="font-sans text-xs font-medium tracking-[0.14em] text-muted">03</span>
            <h3 class="mx-0 mt-3.5 mb-3 font-display font-medium text-[27px] leading-[1.15] text-ink">SEO &amp; Content Strategy</h3>
            <p class="m-0 font-sans text-[15px] leading-[1.65] text-muted">Multilingual SEO architecture and content strategy for digital platforms targeting Japanese and Spanish-speaking audiences.</p>
          </div>
        </div>
        <a href="/services/" class="mt-10 inline-block border-b border-ink pb-0.5 font-sans text-sm font-medium text-ink no-underline">
          View all services&nbsp;&rarr;
        </a>
      </section>

      <!-- CTA -->
      <section class="mx-auto max-w-[960px] w-full border-t border-border px-[clamp(20px,5vw,40px)] pt-[clamp(56px,8vw,104px)] pb-[clamp(40px,6vw,72px)] text-center">
        <h2 class="m-0 font-display font-medium text-[clamp(38px,6vw,56px)] leading-[1.05] text-ink">Let&rsquo;s talk.</h2>
        <p class="mx-auto mt-5 max-w-[44ch] font-sans text-base leading-[1.7] text-muted">
          Available for consulting projects and collaborations between Spain, Japan and Europe.
        </p>
        <a
          href="/contact/"
          class="mt-8 inline-flex items-center gap-2 rounded bg-accent px-[26px] py-3.5 font-sans text-[15px] font-medium text-white no-underline hover:bg-accent-dark transition-colors duration-200"
        >Get in touch&nbsp;&rarr;</a>
      </section>

    </div>
  </main>
  <Footer />
</BaseLayout>
