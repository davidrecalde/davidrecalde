---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const timeline = [
  { period: '2000 — 2002', city: 'Madrid, Spain', title: 'Technician of Plastic Arts and Design — Furniture', org: 'College of Design, Madrid' },
  { period: '2004 — 2005', city: 'Madrid, Spain', title: 'Master in 3D Animation and Digital Post-Production', org: 'CICE Training Center' },
  { period: '2007 — 2012', city: 'Valencia, Spain', title: 'Degree in Product Design', org: 'EASD School of Art and Design' },
  { period: '2009 — 2010', city: 'Valencia, Spain', title: 'Product Designer', org: 'Ximo Roca Diseño' },
  { period: '2011', city: 'Budapest, Hungary', title: 'Visiting student, Industrial and Product Design', org: 'Moholy-Nagy University of Art and Design' },
  { period: '2011 — 2013', city: 'Valencia, Spain', title: 'Product Designer', org: 'Manufacturas Celda / Uno Design' },
  { period: '2013 — 2014', city: 'Madrid, Spain', title: "Master's Degree in Design", org: 'Complutense University' },
  { period: '2014 — 2016', city: 'Spain', title: 'Product Designer', org: 'T3cnologic' },
  { period: '2017 — 2020', city: 'Tokyo, Japan', title: 'Spanish Language Instructor', org: 'JICA — Japan International Cooperation Agency' },
  { period: '2018 — Present', city: 'Tokyo, Japan', title: 'Founder', org: 'Club Español en Japón · supein.club' },
  { period: '2020 — 2024', city: 'Tokyo, Japan', title: 'Communication Advisor', org: 'Instituto Cervantes Tokyo' },
  { period: '2020 — 2024', city: 'Tokyo, Japan', title: 'Digital Content (Freelance)', org: 'Embassy of Spain in Japan' },
  { period: '2021 — 2023', city: 'Tokyo, Japan', title: 'Communication Advisor', org: 'University of Tokyo, Faculty of Engineering' },
  { period: '2025 — Present', city: 'Tokyo, Japan', title: 'Studio Lead', org: 'NODA.Tokyo' },
];
---
<BaseLayout
  title="About — David Recalde"
  description="Brand and communication strategist based in Tokyo. Background in product design, a decade of experience in Japan. Spain–Japan digital communication."
>
  <Nav currentPage="about" />
  <main id="main-content" class="flex-1">

    <!-- Page header -->
    <section class="hero-enter mx-auto max-w-[960px] w-full px-[clamp(20px,5vw,40px)] pt-[clamp(48px,8vw,96px)] pb-[clamp(36px,5vw,56px)]">
      <p class="mb-4 font-sans text-xs font-medium uppercase tracking-[0.16em] text-muted">(02) About</p>
      <h1 class="m-0 font-display font-medium text-[clamp(44px,7vw,72px)] leading-none tracking-[-0.02em] text-ink">About</h1>
    </section>

    <!-- Bio + photo -->
    <section data-reveal class="mx-auto max-w-[960px] w-full px-[clamp(20px,5vw,40px)] pb-[clamp(48px,7vw,80px)]">
      <div class="flex flex-wrap items-start gap-[clamp(32px,5vw,64px)]">
        <div class="min-w-[280px] flex-[1_1_420px]">
          <p class="mb-[22px] font-sans text-[17px] leading-[1.75] text-ink">
            I&rsquo;m David Recalde, a brand and communication strategist based in Tokyo. I grew up in Madrid, studied Product Design in Valencia and Budapest, and completed a Master&rsquo;s degree in Design at the Complutense University of Madrid.
          </p>
          <p class="mb-[22px] font-sans text-[17px] leading-[1.75] text-ink">
            My career began in industrial and product design, working with studios in Madrid and Valencia. After moving to Japan in the mid-2010s, my focus gradually shifted from physical objects to digital communication — branding, editorial design, and the strategy that connects an organization to its audience online.
          </p>
          <p class="m-0 font-sans text-[17px] leading-[1.75] text-ink">
            Today I lead the studio at NODA.Tokyo and run supein.club, a Japanese-language media platform about Spain. Over the past decade I&rsquo;ve advised institutions including the Instituto Cervantes Tokyo, the Embassy of Spain in Japan, JICA and ICEX — helping them communicate clearly across the Spain&ndash;Japan&ndash;Europe space.
          </p>
        </div>
        <div class="min-w-[220px] max-w-[480px] w-full flex-[0_1_380px]">
          <div class="about-photo-composition">
            <div class="apc-row apc-row--top">
              <div class="apc-cell-sm"></div>
              <div class="apc-cell-sm apc-cell--active"></div>
            </div>
            <div class="apc-row apc-row--main">
              <div class="apc-photo">
                <img
                  src="/images/david-recalde.jpg"
                  alt="David Recalde — Brand & Communication Strategist based in Tokyo"
                  width="680"
                  height="680"
                  loading="lazy"
                />
              </div>
            </div>
            <div class="apc-row apc-row--bottom">
              <div class="apc-cell-sm"></div>
              <div class="apc-cell-sm"></div>
              <div class="apc-cell-sm"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Career timeline -->
    <section class="mx-auto max-w-[960px] w-full border-t border-border px-[clamp(20px,5vw,40px)] py-[clamp(48px,7vw,88px)]">
      <p class="mb-8 font-sans text-xs font-medium uppercase tracking-[0.16em] text-muted">Career</p>
      <div class="career-track">
        <div class="career-line-bg"></div>
        <div class="career-line-fill" id="career-line-fill"></div>
        {timeline.map((item) => (
          <div class="career-entry">
            <span class="career-dot"></span>
            <p class="career-date">{item.period}</p>
            <p class="career-city">{item.city}</p>
            <p class="career-title">{item.title}</p>
            <p class="career-org">{item.org}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Focus + Education -->
    <section data-reveal style="--reveal-delay:50ms" class="mx-auto max-w-[960px] w-full border-t border-border px-[clamp(20px,5vw,40px)] py-[clamp(48px,7vw,88px)]">
      <div class="grid grid-cols-[repeat(auto-fit,minmax(260px,1fr))] gap-[clamp(40px,6vw,72px)]">
        <div>
          <p class="mb-6 font-sans text-xs font-medium uppercase tracking-[0.16em] text-muted">What I focus on</p>
          <ul class="m-0 list-none p-0">
            <li class="border-b border-border py-[13px] font-sans text-base leading-[1.6] text-ink">Digital communication strategy</li>
            <li class="border-b border-border py-[13px] font-sans text-base leading-[1.6] text-ink">Branding &amp; editorial design</li>
            <li class="border-b border-border py-[13px] font-sans text-base leading-[1.6] text-ink">Multilingual SEO &amp; content</li>
            <li class="py-[13px] font-sans text-base leading-[1.6] text-ink">Spain&ndash;Japan&ndash;Europe positioning</li>
          </ul>
        </div>
        <div>
          <p class="mb-6 font-sans text-xs font-medium uppercase tracking-[0.16em] text-muted">Education</p>
          <div class="border-b border-border py-[13px]">
            <p class="m-0 font-sans text-base leading-[1.5] text-ink">Master&rsquo;s degree in Design</p>
            <p class="mt-1 font-sans text-sm leading-[1.5] text-muted">Complutense University of Madrid</p>
          </div>
          <div class="py-[13px]">
            <p class="m-0 font-sans text-base leading-[1.5] text-ink">Product Design</p>
            <p class="mt-1 font-sans text-sm leading-[1.5] text-muted">Valencia &amp; Budapest</p>
          </div>
        </div>
      </div>
      <a href="/contact/" class="mt-12 inline-block border-b border-ink pb-0.5 font-sans text-sm font-medium text-ink no-underline">
        Get in touch&nbsp;&rarr;
      </a>
    </section>

    <!-- Institutions -->
    <section data-reveal style="--reveal-delay:50ms" class="mx-auto max-w-[960px] w-full border-t border-border px-[clamp(20px,5vw,40px)] py-[clamp(48px,7vw,88px)]">
      <p class="mb-4 font-sans text-xs font-medium uppercase tracking-[0.16em] text-muted">Institutions I've worked with</p>
      <div class="logo-row" style="margin-top: 24px;">
        <img src="/images/logos/instituto-cervantes.svg" alt="Instituto Cervantes Tokyo" loading="lazy" />
        <img src="/images/logos/embassy-spain.svg" alt="Embassy of Spain in Japan" loading="lazy" />
        <img src="/images/logos/jica.svg" alt="JICA — Japan International Cooperation Agency" loading="lazy" />
        <img src="/images/logos/icex.svg" alt="ICEX — Spain Trade and Investment" loading="lazy" />
        <img src="/images/logos/utokyo.svg" alt="University of Tokyo" loading="lazy" />
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script>
  import { initCareerTimeline, initHoverPolish } from '../scripts/scroll-animations';
  initCareerTimeline();
  initHoverPolish();
</script>
