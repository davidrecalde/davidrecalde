---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="About — David Recalde"
  description="Brand and communication strategist based in Tokyo. Background in product design, a decade of experience in Japan. Spain–Japan digital communication."
>
  <Nav currentPage="about" />
  <main id="main-content" class="flex-1">

    <!-- Page header -->
    <section class="hero-enter mx-auto max-w-[960px] w-full px-[clamp(20px,5vw,40px)] pt-[clamp(48px,8vw,96px)] pb-[clamp(36px,5vw,56px)]">
      <h2 class="mb-4 font-sans text-xs font-medium uppercase tracking-[0.16em] text-muted">(02) About</h2>
      <h1 class="m-0 font-display font-medium text-[clamp(44px,7vw,72px)] leading-none tracking-[-0.02em] text-ink">Profile</h1>
    </section>

    <!-- Bio + photo -->
    <section data-reveal class="mx-auto max-w-[960px] w-full px-[clamp(20px,5vw,40px)] pb-[clamp(48px,7vw,80px)]">
      <div class="flex flex-wrap items-start gap-[clamp(32px,5vw,64px)]">
        <div class="min-w-[280px] flex-[1_1_420px]">
          <p class="mb-[22px] font-sans text-[17px] leading-[1.75] text-ink">
            David Recalde is a Brand &amp; Communication Strategist based in Tokyo. Born in Madrid in 1982, he studied Product Design in Valencia and Budapest before completing a Master&rsquo;s degree in Design at the Complutense University of Madrid.
          </p>
          <p class="mb-[22px] font-sans text-[17px] leading-[1.75] text-ink">
            His early career was shaped by a deep interest in the history and methodology of design, and a process that has always started with sketching &mdash; treating drawing not as a final output but as a tool for thinking. That same curiosity later drew him toward new technologies applied to digital creation, as his practice expanded from physical products into communication, branding and digital strategy.
          </p>
          <p class="mb-[22px] font-sans text-[17px] leading-[1.75] text-ink">
            Since relocating to Japan, his work has centered on cultural management, event production and institutional communication for organizations operating between Spain and Japan. He is known for building teams and adapting with ease across diverse professional environments, driven by a consistent focus on creativity paired with practical execution.
          </p>
          <p class="m-0 font-sans text-[17px] leading-[1.75] text-ink">
            He currently leads the studio at NODA.Tokyo and founded supein.club, a Japanese-language platform about Spain. He is available for select consulting engagements.
          </p>
        </div>
        <div class="min-w-[220px] max-w-[480px] w-full flex-[0_1_380px]">
          <div class="about-photo-composition">
            <div class="apc-row apc-row--top">
              <div class="apc-cell-sm"></div>
              <div class="apc-cell-sm apc-cell--active"></div>
            </div>
            <div class="apc-row apc-row--main">
              <div class="apc-photo">
                <img
                  src="/images/david-recalde.jpg"
                  alt="David Recalde — Brand & Communication Strategist based in Tokyo"
                  width="680"
                  height="680"
                  loading="lazy"
                />
              </div>
            </div>
            <div class="apc-row apc-row--bottom">
              <div class="apc-cell-sm"></div>
              <div class="apc-cell-sm"></div>
              <div class="apc-cell-sm"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What I focus on + Education -->
    <section data-reveal style="--reveal-delay:50ms" class="mx-auto max-w-[960px] w-full border-t border-border px-[clamp(20px,5vw,40px)] py-[clamp(48px,7vw,88px)]">
      <div class="grid grid-cols-[repeat(auto-fit,minmax(260px,1fr))] gap-[clamp(40px,6vw,72px)]">
        <div>
          <h2 class="mb-6 font-sans text-xs font-medium uppercase tracking-[0.16em] text-muted">What I focus on</h2>
          <ul class="m-0 list-none p-0">
            <li class="border-b border-border py-[13px] font-sans text-base leading-[1.6] text-ink">Digital communication strategy</li>
            <li class="border-b border-border py-[13px] font-sans text-base leading-[1.6] text-ink">Branding &amp; editorial design</li>
            <li class="border-b border-border py-[13px] font-sans text-base leading-[1.6] text-ink">Multilingual SEO &amp; content</li>
            <li class="py-[13px] font-sans text-base leading-[1.6] text-ink">Spain&ndash;Japan&ndash;Europe positioning</li>
          </ul>
        </div>
        <div>
          <h2 class="mb-6 font-sans text-xs font-medium uppercase tracking-[0.16em] text-muted">Education</h2>
          <div class="border-b border-border py-[13px]">
            <p class="m-0 font-sans text-base leading-[1.5] text-ink">Master&rsquo;s degree in Design</p>
            <p class="mt-1 font-sans text-sm leading-[1.5] text-muted">Complutense University of Madrid</p>
          </div>
          <div class="py-[13px]">
            <p class="m-0 font-sans text-base leading-[1.5] text-ink">Product Design</p>
            <p class="mt-1 font-sans text-sm leading-[1.5] text-muted">Valencia &amp; Budapest</p>
          </div>
        </div>
      </div>
      <a href="/contact/" class="mt-12 inline-block border-b border-ink pb-0.5 font-sans text-sm font-medium text-ink no-underline">
        Get in touch&nbsp;&rarr;
      </a>
    </section>

    <!-- Institutions -->
    <section data-reveal style="--reveal-delay:50ms" class="mx-auto max-w-[960px] w-full border-t border-border px-[clamp(20px,5vw,40px)] py-[clamp(48px,7vw,88px)]">
      <h2 class="mb-4 font-sans text-xs font-medium uppercase tracking-[0.16em] text-muted">Institutions I've worked with</h2>
      <div class="logo-row" style="margin-top: 24px;">
        <img src="/images/logos/instituto-cervantes.svg" alt="Instituto Cervantes Tokyo" loading="lazy" />
        <img src="/images/logos/embassy-spain.svg" alt="Embassy of Spain in Japan" loading="lazy" />
        <img src="/images/logos/jica.svg" alt="JICA — Japan International Cooperation Agency" loading="lazy" />
        <img src="/images/logos/icex.svg" alt="ICEX — Spain Trade and Investment" loading="lazy" />
        <img src="/images/logos/utokyo.svg" alt="University of Tokyo" loading="lazy" />
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
