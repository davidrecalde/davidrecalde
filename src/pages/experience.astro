---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const timeline = [
  { period: '2025 — Present', role: 'Studio Lead', org: 'NODA.Tokyo', location: 'Tokyo' },
  { period: '2018 — Present', role: 'Founder', org: 'Club Español en Japón', extra: 'スペイン倶楽部' },
  { period: '2020 — 2024', role: 'Communication Advisor', org: 'Instituto Cervantes Tokyo' },
  { period: '2017 — 2020', role: 'Spanish Language Instructor', org: 'JICA', extra: 'Japan International Cooperation Agency' },
];

const clients = [
  'Instituto Cervantes Tokyo',
  'Embassy of Spain in Japan',
  'JICA',
  'ICEX — Spain Trade and Investment',
  'University of Tokyo',
  'NODA.Tokyo',
];

const skills = [
  'Digital Communication', 'Branding', 'Editorial Design', 'SEO',
  'Content Strategy', 'Product Design', 'Art Direction',
  'Multilingual Content', 'Spanish', 'Japanese', 'English',
];
---
<BaseLayout
  title="Experience — David Recalde"
  description="Career timeline, clients and skills. Over a decade of experience in digital communication, branding and SEO between Spain and Japan."
>
  <Nav currentPage="experience" />
  <main class="flex-1">
    <div class="animate-fade-up">

      <!-- Page header -->
      <section class="mx-auto max-w-[960px] w-full px-[clamp(20px,5vw,40px)] pt-[clamp(44px,7vw,88px)] pb-[clamp(32px,4vw,48px)]">
        <p class="mb-4 font-sans text-xs font-medium uppercase tracking-[0.16em] text-muted">Career</p>
        <h1 class="m-0 font-display font-medium text-[clamp(44px,7vw,72px)] leading-none tracking-[-0.01em] text-ink">Experience</h1>
      </section>

      <!-- Timeline -->
      <section class="mx-auto max-w-[960px] w-full px-[clamp(20px,5vw,40px)] pb-[clamp(40px,6vw,64px)]">
        <div class="ml-[3px] max-w-[680px] border-l border-border">
          {timeline.map((item, i) => (
            <div class:list={['relative pl-8', i < timeline.length - 1 ? 'pb-[38px]' : 'pb-1']}>
              <span class="absolute -left-1 top-[7px] h-[7px] w-[7px] rounded-full bg-ink"></span>
              <p class="mb-[7px] font-sans text-xs font-medium uppercase tracking-[0.1em] text-muted">{item.period}</p>
              <p class="m-0 font-sans text-lg font-semibold text-ink">{item.role}</p>
              <p class="mt-[3px] font-sans text-[15px] text-muted">
                {item.org}{item.location && <>&nbsp;&middot;&nbsp;{item.location}</>}{item.extra && <>&nbsp;&middot;&nbsp;{item.extra}</>}
              </p>
            </div>
          ))}
        </div>
      </section>

      <!-- Clients -->
      <section class="mx-auto max-w-[960px] w-full border-t border-border px-[clamp(20px,5vw,40px)] py-[clamp(40px,6vw,64px)]">
        <p class="mb-6 font-sans text-xs font-medium uppercase tracking-[0.16em] text-muted">Clients &amp; collaborations</p>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-x-[clamp(32px,5vw,56px)]">
          {clients.map(name => (
            <p class="m-0 border-b border-border py-3 font-sans text-base text-ink">{name}</p>
          ))}
        </div>
      </section>

      <!-- Skills -->
      <section class="mx-auto max-w-[960px] w-full border-t border-border px-[clamp(20px,5vw,40px)] py-[clamp(40px,6vw,64px)]">
        <p class="mb-6 font-sans text-xs font-medium uppercase tracking-[0.16em] text-muted">Skills</p>
        <div class="flex flex-wrap gap-2.5">
          {skills.map(skill => (
            <span class="rounded-full border border-border bg-white px-[15px] py-2 font-sans text-[11px] font-medium uppercase tracking-[0.1em] text-ink">
              {skill}
            </span>
          ))}
        </div>
      </section>

    </div>
  </main>
  <Footer />
</BaseLayout>
