---
const year = new Date().getFullYear();
---
<footer class="shrink-0 border-t border-border">
  <div class="mx-auto max-w-[960px] w-full px-[clamp(20px,5vw,40px)] py-[clamp(36px,5vw,52px)]">
    <div class="flex flex-wrap items-center justify-between gap-x-10 gap-y-5">
      <a href="/" class="font-sans text-base text-ink no-underline inline-flex gap-[0.25em]">
        <span class="font-light">David</span><span class="font-bold">Recalde</span>
      </a>
      <div class="flex flex-wrap gap-6">
        <a href="https://www.linkedin.com/in/davidgarciarecalde/" target="_blank" rel="noopener" class="font-sans text-[13px] font-medium tracking-[0.04em] text-muted no-underline hover:text-ink transition-colors duration-200">LinkedIn</a>
        <a href="https://www.instagram.com/davidrecalde/" target="_blank" rel="noopener" class="font-sans text-[13px] font-medium tracking-[0.04em] text-muted no-underline hover:text-ink transition-colors duration-200">Instagram</a>
      </div>
    </div>
    <p class="mt-7 font-sans text-xs text-muted">&copy; {year} Made in Tokyo with love by <a href="https://noda.tokyo" target="_blank" rel="noopener" class="text-muted no-underline border-b border-transparent hover:text-ink hover:border-ink transition-colors duration-200">NODA</a></p>
  </div>
</footer>
