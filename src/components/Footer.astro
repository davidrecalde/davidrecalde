---
const year = new Date().getFullYear();
---
<footer class="shrink-0 border-t border-border">
  <div class="mx-auto max-w-[960px] w-full px-[clamp(20px,5vw,40px)] py-[clamp(36px,5vw,52px)]">
    <div class="flex flex-wrap items-center justify-between gap-x-10 gap-y-5">
      <a href="/" class="font-sans text-base font-semibold text-ink no-underline">
        David Recalde<span class="text-accent">·</span>
      </a>
      <div class="flex flex-wrap gap-6">
        <a href="https://www.linkedin.com/in/davidrecalde/" target="_blank" rel="noopener" class="font-sans text-[13px] font-medium tracking-[0.04em] text-muted no-underline hover:text-ink transition-colors duration-200">LinkedIn</a>
        <a href="https://noda.tokyo" target="_blank" rel="noopener" class="font-sans text-[13px] font-medium tracking-[0.04em] text-muted no-underline hover:text-ink transition-colors duration-200">NODA.Tokyo</a>
        <a href="https://supein.club" target="_blank" rel="noopener" class="font-sans text-[13px] font-medium tracking-[0.04em] text-muted no-underline hover:text-ink transition-colors duration-200">supein.club</a>
      </div>
    </div>
    <p class="mt-7 font-sans text-xs text-muted">
      &copy; {year} David Recalde &mdash; Tokyo, Japan
      <span class="ml-1">&middot; Site by <a href="https://noda.tokyo" target="_blank" rel="noopener" class="text-muted no-underline border-b border-transparent hover:text-ink hover:border-ink transition-colors duration-200">NODA</a></span>
    </p>
  </div>
</footer>
