---
interface Props {
  columns?: number;
  rows?: number;
  activeCell?: number;
  class?: string;
}
const { columns = 6, rows = 4, activeCell, class: className = '' } = Astro.props;
const totalCells = columns * rows;
---
<div class={`grid-system ${className}`} style={`grid-template-columns: repeat(${columns}, 1fr);`}>
  {Array.from({ length: totalCells }).map((_, i) => (
    <div class={`grid-system-cell ${activeCell === i ? 'grid-system-cell--active' : ''}`}></div>
  ))}
</div>

<style>
  .grid-system {
    display: grid;
    gap: 8px;
    width: 100%;
    height: 100%;
  }
  .grid-system-cell {
    aspect-ratio: 4 / 3;
    background: #EAEAEA;
    border-radius: 1px;
  }
  .grid-system-cell--active {
    background: var(--color-ink);
  }
</style>
